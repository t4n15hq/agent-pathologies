# API keys for the v2.3 provider mix.
#
# Recommended hybrid (cheapest for our sweep):
#   - DeepSeek direct  → both V4 models (75% promo on v4-pro through 2026-05-31)
#   - OpenRouter       → all four Qwen models
#   - Anthropic direct → Claude Opus 4.7 anchor (gains prompt caching at $0.50/M reads)

# DeepSeek direct (https://platform.deepseek.com/api_keys).
# Used for: deepseek-v4-pro (reasoning on/off), deepseek-v4-flash (reasoning on/off).
DEEPSEEK_API_KEY=

# OpenRouter (https://openrouter.ai/keys).
# Used for: the four Qwen3 models. Provider routing is pinned per-model in
# configs/models.yaml — verify each upstream name at openrouter.ai/<model>/providers.
OPENROUTER_API_KEY=

# Anthropic direct (https://console.anthropic.com/settings/keys).
# Used for: claude-opus-4.7 anchor. If your Anthropic Max plan includes API
# credits, this key spends those before any pay-as-you-go billing.
ANTHROPIC_API_KEY=

# Optional alternative routes (only needed if you swap providers in configs/models.yaml).
OPENAI_API_KEY=
TOGETHER_API_KEY=
FIREWORKS_API_KEY=

# Local vLLM / Ollama need no key.
